# ============================================================
# SAP HANA Cloud KGE Workshop — 연결 정보
# 이 파일을 복사해서 .env 로 이름을 바꾸고 값을 채워주세요:
#   cp .env.example .env
# ============================================================

# HANA Cloud
HANA_HOST=your-host.hanacloud.ondemand.com
HANA_PORT=443
HANA_USER=your-user
HANA_PASSWORD=your-password

# 참가자 번호 — 발표자가 배포한 두 자리 숫자로 변경하세요 (예: 01, 02, ... 30)
MY_NUMBER=XX

# AI Core 설정은 ~/.aicore/config.json 에서 전역으로 관리합니다
# README.md 의 "SAP AI Core 설정" 섹션을 참고하세요
